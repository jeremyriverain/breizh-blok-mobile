          "sql": "CREATE TABLE IF NOT EXISTS \"boulder_geo_point_table\" (\"id\" INTEGER NOT NULL, \"lat\" REAL NOT NULL, \"lng\" REAL NOT NULL, \"area_id\" INTEGER NOT NULL, PRIMARY KEY (\"id\")) STRICT;"
        }
      ]
    },
    {
      "name": "db_requests",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"db_requests\" (\"request_path\" TEXT NOT NULL, \"response_body\" TEXT NOT NULL, PRIMARY KEY (\"request_path\"));"
        }
      ]
    },
    {
      "name": "db_boulder_areas",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"db_boulder_areas\" (\"iri\" TEXT NOT NULL, \"download_progress\" INTEGER NOT NULL, \"boulders\" TEXT NULL REFERENCES db_requests (request_path), \"downloaded_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP), PRIMARY KEY (\"iri\"));"
        }
      ]
    },
    {
      "name": "department_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"department_table\" (\"iri\" TEXT NOT NULL, \"name\" TEXT NOT NULL, PRIMARY KEY (\"iri\")) STRICT;"
        }
      ]
    },
    {
      "name": "grade_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"grade_table\" (\"iri\" TEXT NOT NULL, \"name\" TEXT NOT NULL UNIQUE, PRIMARY KEY (\"iri\")) STRICT;"
        }
      ]
    },
    {
      "name": "municipality_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"municipality_table\" (\"iri\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"department\" TEXT NULL REFERENCES department_table (iri), PRIMARY KEY (\"iri\")) STRICT;"
        }
      ]
